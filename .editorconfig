root = true

# =============================================================================
# Default: all files
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# =============================================================================
# Python
# =============================================================================
[*.py]
indent_size = 4
max_line_length = 100

[*.pyi]
indent_size = 4

# =============================================================================
# TypeScript / JavaScript / JSX / TSX
# =============================================================================
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# =============================================================================
# Web assets
# =============================================================================
[*.{html,css,scss,sass,less}]
indent_size = 2

# =============================================================================
# JSON
# =============================================================================
[*.json]
indent_size = 2

[*.jsonc]
indent_size = 2

# package.json gets 2-space indent (managed by npm/pnpm tooling)
[package.json]
indent_size = 2

# =============================================================================
# YAML
# =============================================================================
[*.{yml,yaml}]
indent_size = 2

# =============================================================================
# TOML
# =============================================================================
[*.toml]
indent_size = 4

# =============================================================================
# Markdown
# =============================================================================
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# =============================================================================
# Shell scripts
# =============================================================================
[*.sh]
indent_size = 2
shell_variant = bash

# =============================================================================
# Makefile — MUST use tabs
# =============================================================================
[Makefile]
indent_style = tab
indent_size = 4

# =============================================================================
# Docker
# =============================================================================
[Dockerfile*]
indent_size = 4

[docker-compose*.yml]
indent_size = 2

# =============================================================================
# Git config
# =============================================================================
[.gitconfig]
indent_style = tab

# =============================================================================
# SQL
# =============================================================================
[*.sql]
indent_size = 2
