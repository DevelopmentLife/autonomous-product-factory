# =============================================================================
# APF Environment Configuration
#
# Copy this file to .env and fill in the values you need.
# Everything is optional except APF_SECRET_KEY and APF_ADMIN_PASSWORD.
# The pipeline runs in mock mode if no LLM key is set.
#
# NEVER commit .env to version control.
# =============================================================================


# =============================================================================
# REQUIRED — APF won't start without these two
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APF_SECRET_KEY=CHANGE_ME

# Password for the admin dashboard login
APF_ADMIN_PASSWORD=changeme


# =============================================================================
# LLM Provider — pick one, or leave all blank to run in mock mode
# =============================================================================

# Mock mode: set to "true" to run the full pipeline with zero API calls.
# Agents return realistic-looking placeholder artifacts.
# Great for testing the pipeline flow, dashboard, and connector wiring locally.
MOCK_LLM=false

# --- Anthropic (recommended) ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
ANTHROPIC_API_KEY=

# --- OpenAI (alternative) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=

# --- LiteLLM / Ollama / any local model (alternative) ---
# LLM_PROVIDER=litellm
# LLM_MODEL=ollama/llama3
# LITELLM_BASE_URL=http://localhost:11434


# =============================================================================
# GitHub — optional; enables automatic PR creation
#
# Without these, the pipeline completes and artifacts are stored but no PR
# is opened. You can still download artifacts via the CLI or dashboard.
#
# Setup: https://github.com/settings/apps/new
# Permissions needed: Contents: write, Pull requests: write
# =============================================================================
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_REPO=yourorg/yourrepo
GITHUB_DEFAULT_BASE_BRANCH=main


# =============================================================================
# Slack — optional; enables pipeline notifications and HITL approvals
#
# Without these, the slack-connector service won't start (profile not needed).
#
# Setup: https://api.slack.com/apps -> Create App -> Bot Token Scopes: chat:write
# =============================================================================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=#apf-pipelines


# =============================================================================
# AWS (ECS deployment) — optional; used by the aws-connector service
#
# Set these if you want the DevOps agent to trigger an ECS deployment after
# a pipeline completes. Leave blank to skip AWS deployment.
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ECS_CLUSTER=
AWS_ECS_SERVICE=
AWS_ECS_TASK_DEFINITION=


# =============================================================================
# Jira — optional connector (profile: jira)
# =============================================================================
JIRA_URL=
JIRA_USER=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=APF


# =============================================================================
# Confluence — optional connector (profile: confluence)
# =============================================================================
CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=APF
CONFLUENCE_PARENT_PAGE_ID=


# =============================================================================
# Database — defaults to SQLite (local.yml) or PostgreSQL (docker-compose.yml)
# You don't need to set this for local development.
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://apf:apf_dev_password@postgres:5432/apf


# =============================================================================
# Redis — defaults to the redis container, override if you have an external one
# =============================================================================
# REDIS_URL=redis://localhost:6379/0


# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
