# =============================================================================
# APF Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://apf:apf_dev_password@postgres:5432/apf
POSTGRES_USER=apf
POSTGRES_PASSWORD=apf_dev_password
POSTGRES_DB=apf

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# MinIO / Object Storage
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=apf_minio
MINIO_ROOT_PASSWORD=apf_minio_password
MINIO_BUCKET=apf-artifacts
MINIO_USE_SSL=false

# =============================================================================
# APF Application Security
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APF_SECRET_KEY=CHANGE_ME_generate_a_secure_random_key_at_least_32_chars
APF_JWT_ALGORITHM=HS256
APF_JWT_EXPIRE_MINUTES=60

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Provider options: anthropic, openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6

# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# OpenAI (optional, used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# =============================================================================
# GitHub App Integration
# =============================================================================
# Create a GitHub App at: https://github.com/settings/apps/new
GITHUB_APP_ID=
# Multi-line PEM key — wrap in quotes, use \n for newlines, or mount as a file
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=CHANGE_ME_generate_a_random_string

# =============================================================================
# Slack Integration
# =============================================================================
# Create a Slack App at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-REPLACE_WITH_YOUR_BOT_TOKEN
SLACK_SIGNING_SECRET=REPLACE_WITH_YOUR_SIGNING_SECRET
SLACK_APP_TOKEN=xapp-REPLACE_WITH_YOUR_APP_TOKEN

# =============================================================================
# Jira Integration
# =============================================================================
# Your Atlassian instance URL, e.g. https://mycompany.atlassian.net
JIRA_URL=https://REPLACE.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=REPLACE_WITH_YOUR_JIRA_API_TOKEN
# The Jira project key for APF-managed work, e.g. APF
JIRA_PROJECT_KEY=APF

# =============================================================================
# Confluence Integration
# =============================================================================
# Your Atlassian instance URL (usually same as Jira)
CONFLUENCE_URL=https://REPLACE.atlassian.net
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=REPLACE_WITH_YOUR_CONFLUENCE_API_TOKEN
# The Confluence space key where docs will be written
CONFLUENCE_SPACE_KEY=APF

# =============================================================================
# AWS Integration
# =============================================================================
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1
# ECS cluster name for agent task execution
AWS_ECS_CLUSTER=apf-agents
# Optional: VPC subnet IDs for ECS tasks (comma-separated)
AWS_ECS_SUBNETS=
# Optional: Security group IDs for ECS tasks (comma-separated)
AWS_ECS_SECURITY_GROUPS=

# =============================================================================
# Observability
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# OpenTelemetry collector endpoint (leave blank to disable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=
# Service name reported to the collector
OTEL_SERVICE_NAME=apf

# =============================================================================
# Dashboard (Frontend)
# =============================================================================
# These are build-time env vars for the Vite frontend
VITE_ORCHESTRATOR_URL=http://localhost:8000
VITE_ARTIFACT_STORE_URL=http://localhost:8001
